# Backend function secrets
# Set these as Firebase Functions secrets in production.

# Brevo API key
# Brevo dashboard -> SMTP & API -> API keys
BREVO_API_KEY=

# Verified sender email configured in Brevo
BREVO_SENDER_EMAIL=

# Sender display name shown in emails
BREVO_SENDER_NAME=AI Unplugged

# Comma-separated emails that should become bootstrap admins
# Example: founder@yourdomain.com,ops@yourdomain.com
BOOTSTRAP_ADMIN_EMAILS=
