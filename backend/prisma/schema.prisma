generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  uid                  String   @id
  email                String   @unique
  displayName          String?
  role                 Role     @default(USER)
  newsletterSubscribed Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  registrations EventRegistration[]
  skills        Skill[]
  comments      Comment[]
}

model NewsletterSubscriber {
  id        String   @id
  email     String   @unique
  status    String
  userId    String?
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id           String   @id @default(cuid())
  title        String
  publishState String   @default("draft")
  entry        String   @default("application")
  formId       String?
  date         DateTime?
  location     String?
  mapAddress   String?
  mapLat       Float?
  mapLng       Float?
  extra        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  registrations EventRegistration[]
  invites       EventInvite[]

  @@index([publishState])
}

model EventInvite {
  id         String    @id @default(cuid())
  eventId    String
  email      String
  name       String?
  token      String    @unique
  status     String    @default("pending")
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@index([eventId])
  @@index([status])
}

model EventForm {
  id        String   @id @default(cuid())
  kind      String
  isDefault Boolean  @default(false)
  title     String
  fields    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, isDefault])
}

model EventRegistration {
  id                     String   @id @default(cuid())
  registrationId         String   @unique
  eventId                String
  eventTitle             String?
  formId                 String?
  formTitle              String?
  formSchema             Json?
  answers                Json
  reviewStatus           String   @default("pending")
  source                 String?
  userId                 String?
  name                   String?
  email                  String?
  organization           String?
  entryType              String?
  waitlistReason         String?
  inviteId               String?
  subscribedToNewsletter Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  event Event? @relation(fields: [eventId], references: [id], onDelete: Restrict)
  user  User?  @relation(fields: [userId], references: [uid], onDelete: SetNull)

  @@index([eventId])
  @@index([userId])
  @@index([reviewStatus])
}

model AppErrorLog {
  id              String   @id @default(cuid())
  route           String?
  method          String?
  statusCode      Int?
  safeMessage     String?
  internalMessage String?
  stack           String?
  userId          String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([statusCode])
}

model NodeLeadApplication {
  id           String   @id @default(cuid())
  formId       String?
  formTitle    String?
  formSchema   Json?
  answers      Json
  email        String?
  name         String?
  reviewStatus String   @default("pending")
  userId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([reviewStatus])
}

model HostApplication {
  id                String   @id @default(cuid())
  answers           Json
  name              String?
  email             String?
  countryCode       String?
  phone             String?
  subject           String?
  venue             String?
  venueCapacity     Int?
  estimatedAudience Int?
  reviewStatus      String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([reviewStatus])
}

model Skill {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  category        String?
  description     String?
  useCase         String?
  fileName        String?
  fileSize        Int?
  filePath        String?
  fileUrl         String?
  markdownContent String?
  publishState    String    @default("pending")
  downloads       Int       @default(0)
  userId          String?
  reviewedAt      DateTime?
  reviewedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [uid], onDelete: SetNull)

  @@index([publishState])
  @@index([userId])
}

model Update {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  excerpt      String?
  body         Json?
  bodyHtml     String?
  category     String    @default("update")
  commentMode  String    @default("moderated")
  publishState String    @default("draft")
  authorName   String?
  scope        String    @default("general")
  eventId      String?
  eventTitle   String?
  attachments  Json?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  comments Comment[]

  @@index([publishState])
  @@index([slug])
}

model Comment {
  id          String   @id @default(cuid())
  updateId    String
  updateSlug  String?
  body        String
  status      String   @default("pending")
  userId      String?
  authorName  String?
  authorEmail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  update Update? @relation(fields: [updateId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [uid], onDelete: SetNull)

  @@index([updateId, status])
}

model Resource {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  sourceLabel  String?
  excerpt      String?
  body         Json?
  bodyHtml     String?
  ctaLabel     String?
  ctaUrl       String?
  image        Json?
  publishState String   @default("draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([publishState])
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model NewsletterCampaign {
  id         String   @id @default(cuid())
  subject    String
  html       String
  text       String?
  recipients Int      @default(0)
  sentAt     DateTime @default(now())
  status     String   @default("sent")
}
