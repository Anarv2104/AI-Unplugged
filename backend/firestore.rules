rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // Users may update their own profile but cannot elevate their own role
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if resource.data.publishState == "published" || isAdmin();
      allow write: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if settingId == "home" || settingId == "resources";
      allow write: if isAdmin();
    }

    match /eventForms/{formId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /eventRegistrations/{registrationId} {
      allow read, write: if isAdmin();
    }

    match /nodeLeadApplications/{applicationId} {
      allow read, write: if isAdmin();
    }

    match /updates/{updateId} {
      allow read: if resource.data.publishState == "published" || isAdmin();
      allow write: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if resource.data.publishState == "published" || isAdmin();
      allow write: if isAdmin();
    }

    match /skills/{skillId} {
      allow read: if isAdmin() || (
        resource.data.kind != "meta"
        && (
          resource.data.publishState == "published"
          || isOwner(resource.data.userId)
        )
      );
      allow create: if (
        skillId == "__skilldb_meta__"
        && isSignedIn()
        && request.resource.data.kind == "meta"
      ) || (
        isSignedIn()
        && request.resource.data.kind == "skill"
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.publishState == "pending"
      );
      allow update: if isAdmin() || (
        isSignedIn()
        && resource.data.userId == request.auth.uid
        && resource.data.kind == "skill"
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.publishState != "published"
      );
      allow delete: if isAdmin() || (
        isSignedIn()
        && resource.data.kind == "skill"
        && resource.data.userId == request.auth.uid
      );
    }

    match /comments/{commentId} {
      allow read: if resource.data.status == "approved" || isAdmin();
      allow write: if isAdmin();
    }

    match /newsletterSubscribers/{subscriberId} {
      allow read, write: if isAdmin();
    }

    match /newsletterCampaigns/{campaignId} {
      allow read, write: if isAdmin();
    }
  }
}
