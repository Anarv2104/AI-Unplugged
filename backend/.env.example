# Backend config
PORT=8000

# Postgres (local on the same server). Replace user/password/host as needed.
DATABASE_URL=postgresql://aiu:CHANGE_ME@localhost:5432/aiunplugged

# Upload storage. Local is the default for development/demo.
STORAGE_DRIVER=local

# Where uploaded files are stored on disk when STORAGE_DRIVER=local. Defaults to backend/uploads if unset.
UPLOAD_DIR=./uploads

# Optional S3/object-storage mode. Leave blank unless STORAGE_DRIVER=s3.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Local structured log files. Defaults to backend/logs if unset.
LOG_DIR=./logs

# Public origin used to build absolute file URLs (e.g. https://your-domain.com).
# Leave empty in local dev; the frontend will hit /uploads/... via the same origin.
PUBLIC_BASE_URL=

# Firebase Admin SDK (auth verification only)
# Generate from Firebase Console -> Project settings -> Service accounts -> Generate new private key
# Store the downloaded JSON inside backend/ and point to it here.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Brevo mail settings
BREVO_API_KEY=replace-with-rotated-brevo-api-key
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=AI Unplugged

# Comma-separated bootstrap admins who become admins on first sync/login
BOOTSTRAP_ADMIN_EMAILS=founder@example.com,ops@example.com
