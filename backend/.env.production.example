# Production backend environment
# Copy to the hosting provider's environment variable panel or backend/.env on a VPS.
# Do not commit real production secrets.

PORT=8000

# Required: hosted Postgres. Do not use Homebrew/local Postgres in production.
# Examples:
# postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Required: final public origin used in emails and absolute upload URLs.
PUBLIC_BASE_URL=https://your-domain.com

# Upload storage. Use local with persistent disk, or s3 with object storage.
STORAGE_DRIVER=local

# Required if using local filesystem uploads. Must point to persistent storage.
UPLOAD_DIR=./uploads

# Optional when STORAGE_DRIVER=s3.
# With AWS IAM roles, omit access keys and grant the host role S3 permissions.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Optional: structured backend logs. Must point to persistent storage if you need logs after restarts.
LOG_DIR=./logs

# Required: Firebase Admin SDK service account file path.
# On VPS: place the JSON file at this path.
# On managed platforms: store the JSON as a secret file if supported, or provision it during deploy.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Required: Brevo transactional/campaign email.
BREVO_API_KEY=replace-with-company-brevo-api-key
BREVO_SENDER_EMAIL=verified-sender@your-domain.com
BREVO_SENDER_NAME=AI Unplugged

# Required: comma-separated admin emails that should become admins after login/sync.
BOOTSTRAP_ADMIN_EMAILS=admin1@your-domain.com,admin2@your-domain.com
