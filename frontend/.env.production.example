# Production frontend environment
# These values come from Firebase Console -> Project settings -> General -> Web app.
# Do not commit real production secrets if the company treats these as private.

VITE_FIREBASE_API_KEY=replace-with-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
VITE_FIREBASE_APP_ID=replace-with-app-id

# Optional region label kept for compatibility with existing config helpers.
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
